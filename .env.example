# Defina o ambiente
NODE_ENV=development
LOG_LEVEL=debug
PROJECT_NAME=backend_template_reborn

# App
APP_NAME="Backend Template Reborn"
APP_PORT=3000
# String secreta para assinar tokens JWT (use uma string longa e aleatória, ex: openssl rand -base64 32)
JWT_SECRET=
FRONTEND_URL=http://localhost:5173
HASH_SALT_ROUNDS=12
# URL do projeto no Sentry para monitoramento de erros (obtenha em sentry.io)
SENTRY_DSN=

# Comando de inicialização
COMMAND="npm run start:dev"

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backend_template_reborn
POSTGRES_PORT=5432
SCHEMA=public

# URLs de conexão
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend_template_reborn?schema=public"

# SMTP
# Email do remetente (ex: noreply@seudominio.com)
SMTP_EMAIL=
# Senha ou token de autenticação do email
SMTP_PASSWORD=
# Porta do servidor SMTP (587 para TLS, 465 para SSL, 25 para conexão não segura)
SMTP_PORT=
# Endereço do servidor SMTP (ex: smtp.gmail.com, smtp.mailtrap.io)
SMTP_HOST=
# Use true para SSL (porta 465) ou false para TLS (porta 587)
SMTP_SECURE=
